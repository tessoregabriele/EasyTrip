# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL + pgvector)
DB_NAME=easytrip_db
DB_USER=easytrip_user
DB_PASSWORD=easytrip_password
DB_HOST=localhost
DB_PORT=5432

# CORS - frontend React
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# LLM (per la chat/orchestrazione) - scegli 'groq' o 'gemini'
LLM_PROVIDER=groq
GROQ_API_KEY=
GEMINI_API_KEY=

# Embedding locale per RAG (fastembed, nessuna API esterna, scarica il modello
# al primo utilizzo - richiede connessione internet una tantum)
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSIONS=384
